    "version": "0.2.0",
    "configurations": [
        {
            "name": "Ref Graph Hex Matplotlib (n=3)",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "ref",
                "-n", "3",
                "-g", "structure_matplotlib",
            ]
        },
        {
            "name": "Ref Graph Hex Dot (n=3)",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "ref",
                "-n", "3",
                "-g", "structure_dot"
            ]
        },
        {
            "name": "Ref Graph Hex Terminal Indices (n=3, r=1,2)",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "ref",
                "-n", "3",
                "-g", "layer_indices_terminal",
                "-r", "1,2"
            ]
        },
        {
            "name": "Ref Graph MLP Matplotlib",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "ref",
                "-m", "mlp",
                "-g", "structure_matplotlib"
            ]
        },
        {
            "name": "Hex Net Simulate (n=3)",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "sim",
                "-n", "3",
                "-t", "linear",
                "-ds", "100",
                "-e", "1000"
            ]
        },
        {
            "name": "MLP Net Train",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "train",
                "-m", "mlp",
                "-t", "identity",
            ]
        },
        {
            "name": "MLP Net Train From Previous Run",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "train",
                "-m", "mlp",
                "-t", "identity",
                "-rd", "runs/2025-09-10_21-17_815bed"
            ]
        },
        {
            "name": "Hex Net Train",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "train",
                "-m", "hex",
                "-t", "identity",
                "-r", "1"
            ]
        },
        {
            "name": "Hex Net Train From Previous Run",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "train",
                "-m", "hex",
                "-t", "identity",
                "-r", "1",
                "-rd", "runs/2025-09-10_20-09_fb76e3"
            ]
        },
        {
            "name": "Stats Command",
            "type": "debugpy",
            "request": "launch",
            "program": "cli.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "stats",
                "runs/2025-09-10_20-09_fb76e3"
            ]
        }
    ]
}