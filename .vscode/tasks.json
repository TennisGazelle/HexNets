{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generate All Reference Graphs",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/hexnet",
            "args": [
                "ref",
                "--all"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        }
    ]
}
