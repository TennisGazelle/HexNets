digraph HexNet {
  graph [rankdir=TB, splines=false, nodesep="0.35", ranksep="0.35"];
  node  [shape=circle, fontsize=10, width=0.45, fixedsize=true, zorder=10];
  edge  [penwidth=0.5, dir="none", zorder=1];
  { rank=same; // layer 0
    1;
    4;
  }
  { rank=same; // layer 1
    0;
    3;
    6;
  }
  { rank=same; // layer 2
    2;
    5;
  }
  1 -> 4 [style="invis"];
  0 -> 3 -> 6 [style="invis"];
  2 -> 5 [style="invis"];
  1 -> 0;
  1 -> 3;
  1 -> 6;
  4 -> 0;
  4 -> 3;
  4 -> 6;
  0 -> 2;
  0 -> 5;
  3 -> 2;
  3 -> 5;
  6 -> 2;
  6 -> 5;
}
