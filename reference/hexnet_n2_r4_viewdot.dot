    1;
    3;
    5;
  }
  { rank=same; // layer 2
    0;
    2;
  }
  4 -> 6 [style="invis"];
  1 -> 3 -> 5 [style="invis"];
  0 -> 2 [style="invis"];
  4 -> 1;
  4 -> 3;
  4 -> 5;
  6 -> 1;
  6 -> 3;
  6 -> 5;
  1 -> 0;
  1 -> 2;
  3 -> 0;
  3 -> 2;
  5 -> 0;
